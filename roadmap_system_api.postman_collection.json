		{
			"name": "Learning Path",
			"item": [
				{
					"name": "Get Learning Path",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has success structure\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('success', true);",
									"    pm.expect(jsonData).to.have.property('message');",
									"    pm.expect(jsonData).to.have.property('data');",
									"});",
									"",
									"pm.test(\"Data contains roadmap and units\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.have.property('roadmap');",
									"    pm.expect(jsonData.data).to.have.property('units');",
									"    pm.expect(jsonData.data.units).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Roadmap has required fields\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.roadmap).to.have.property('id');",
									"    pm.expect(jsonData.data.roadmap).to.have.property('title');",
									"    pm.expect(jsonData.data.roadmap).to.have.property('description');",
									"    pm.expect(jsonData.data.roadmap).to.have.property('level');",
									"});",
									"",
									"pm.test(\"Each unit has required base fields\", function () {",
									"    const jsonData = pm.response.json();",
									"    if (jsonData.data.units.length > 0) {",
									"        const unit = jsonData.data.units[0];",
									"        pm.expect(unit).to.have.property('id');",
									"        pm.expect(unit).to.have.property('position');",
									"        pm.expect(unit).to.have.property('unit_type');",
									"        pm.expect(unit).to.have.property('entity');",
									"        pm.expect(unit).to.have.property('is_locked');",
									"        pm.expect(unit).to.have.property('is_completed');",
									"        pm.expect(['lesson', 'quiz', 'challenge']).to.include(unit.unit_type);",
									"    }",
									"});",
									"",
									"pm.test(\"Lesson units have tracking object\", function () {",
									"    const jsonData = pm.response.json();",
									"    const lessonUnits = jsonData.data.units.filter(u => u.unit_type === 'lesson');",
									"    lessonUnits.forEach(unit => {",
									"        pm.expect(unit).to.have.property('tracking');",
									"        pm.expect(unit.tracking).to.have.property('exists');",
									"        pm.expect(unit.tracking).to.have.property('is_complete');",
									"        pm.expect(unit.tracking).to.have.property('last_updated_at');",
									"        pm.expect(unit.tracking.exists).to.be.a('boolean');",
									"        pm.expect(unit.tracking.is_complete).to.be.a('boolean');",
									"        if (unit.tracking.exists) {",
									"            pm.expect(unit.tracking.last_updated_at).to.be.a('string');",
									"        } else {",
									"            pm.expect(unit.tracking.last_updated_at).to.be.null;",
									"        }",
									"    });",
									"});",
									"",
									"pm.test(\"Quiz units have latest_attempt\", function () {",
									"    const jsonData = pm.response.json();",
									"    const quizUnits = jsonData.data.units.filter(u => u.unit_type === 'quiz');",
									"    quizUnits.forEach(unit => {",
									"        pm.expect(unit).to.have.property('latest_attempt');",
									"        if (unit.latest_attempt !== null) {",
									"            pm.expect(unit.latest_attempt).to.have.property('id');",
									"            pm.expect(unit.latest_attempt).to.have.property('passed');",
									"            pm.expect(unit.latest_attempt).to.have.property('score');",
									"            pm.expect(unit.latest_attempt).to.have.property('created_at');",
									"            pm.expect(unit.latest_attempt).to.have.property('updated_at');",
									"        }",
									"    });",
									"});",
									"",
									"pm.test(\"Challenge units have latest_attempt\", function () {",
									"    const jsonData = pm.response.json();",
									"    const challengeUnits = jsonData.data.units.filter(u => u.unit_type === 'challenge');",
									"    challengeUnits.forEach(unit => {",
									"        pm.expect(unit).to.have.property('latest_attempt');",
									"        if (unit.latest_attempt !== null) {",
									"            pm.expect(unit.latest_attempt).to.have.property('id');",
									"            pm.expect(unit.latest_attempt).to.have.property('passed');",
									"            pm.expect(unit.latest_attempt).to.have.property('created_at');",
									"            pm.expect(unit.latest_attempt).to.have.property('updated_at');",
									"        }",
									"    });",
									"});",
									"",
									"pm.test(\"Units are ordered by position\", function () {",
									"    const jsonData = pm.response.json();",
									"    const positions = jsonData.data.units.map(u => u.position);",
									"    const sortedPositions = [...positions].sort((a, b) => a - b);",
									"    pm.expect(positions).to.eql(sortedPositions);",
									"});",
									"",
									"pm.test(\"Save first lessonId if exists\", function () {",
									"    const jsonData = pm.response.json();",
									"    const firstLesson = jsonData.data.units.find(u => u.unit_type === 'lesson');",
									"    if (firstLesson && firstLesson.entity && firstLesson.entity.id) {",
									"        pm.collectionVariables.set('lessonId', firstLesson.entity.id);",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/roadmaps/{{roadmapId}}/learning-path",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"roadmaps",
								"{{roadmapId}}",
								"learning-path"
							]
						},
						"description": "Get learning path for a roadmap. Includes tracking data for lessons and latest attempts for quizzes/challenges. Optimized with batch loading (no N+1 queries)."
					},
					"response": []
				}
			]
		},
