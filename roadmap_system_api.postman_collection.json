									"    pm.expect(jsonData).to.have.property('message');",
									"    pm.expect(jsonData).to.have.property('data');",
									"});",
									"",
									"pm.test(\"Error data contains enrollment info\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.have.property('enrollment_id');",
									"    pm.expect(jsonData.data).to.have.property('roadmap_id');",
									"    pm.expect(jsonData.data).to.have.property('status');",
									"});",
									"",
									"pm.test(\"Message indicates duplicate enrollment\", function () {",
									"    const jsonData = pm.response.json();",
