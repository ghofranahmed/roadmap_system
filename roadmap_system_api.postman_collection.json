				{
					"name": "Enroll in Roadmap",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has success structure\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('success', true);",
									"    pm.expect(jsonData).to.have.property('data');",
									"    pm.expect(jsonData.data).to.have.property('enrollment');",
									"});",
									"",
									"pm.test(\"Enrollment has required fields\", function () {",
									"    const jsonData = pm.response.json();",
									"    const enrollment = jsonData.data.enrollment;",
									"    pm.expect(enrollment).to.have.property('id');",
									"    pm.expect(enrollment).to.have.property('roadmap_id');",
									"    pm.expect(enrollment).to.have.property('status', 'active');",
									"});",
									"",
									"pm.test(\"Save roadmapId variable\", function () {",
									"    const jsonData = pm.response.json();",
									"    if (jsonData.data.enrollment && jsonData.data.enrollment.roadmap_id) {",
									"        pm.collectionVariables.set('roadmapId', jsonData.data.enrollment.roadmap_id);",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
